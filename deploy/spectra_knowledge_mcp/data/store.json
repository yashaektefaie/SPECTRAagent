      "finding_id": "state_pathway_module_train_support_20260603",
      "model": "STATE",
      "domain": "single-cell perturbation response prediction",
      "task": "predict post-perturbation expression response for held-out gene perturbations",
      "metric": {
        "primary": "overlap@N",
        "representations": [
          "HVG",
          "SE"
        ],
        "direction": "higher overlap@N is better"
      },
      "axis": {
        "name": "pathway/module train-support density",
        "type": "prospective gene-set train-support axis",
        "definition": "For each held-out gene perturbation, support is the mean log(1 + number of same-context training genes sharing each pathway/module annotation of the target gene). Higher support means the target gene is closer to known training biology in that context.",
        "primary_collection": "Reactome",
        "independent_collections": [
          "HGNC gene groups",
          "GO Biological Process",
          "GO Molecular Function",
          "GO Cellular Component",
          "WikiPathways",
          "KEGG"
        ]
